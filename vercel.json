{
    "version": 2,
    "builds": [
        {
            "src": "api/**/*.js",
            "use": "@vercel/node"
        },
        {
            "src": "*.html",
            "use": "@vercel/static"
        },
        {
            "src": "*.css",
            "use": "@vercel/static"
        },
        {
            "src": "*.js",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/$1"
        },
        {
            "src": "/",
            "dest": "/index.html"
        },
        {
            "src": "/(index|listings|contacts)\\.html",
            "dest": "/$1.html"
        },
        {
            "src": "/style\\.css",
            "dest": "/style.css"
        },
        {
            "src": "/app\\.js",
            "dest": "/app.js"
        }
    ]
}